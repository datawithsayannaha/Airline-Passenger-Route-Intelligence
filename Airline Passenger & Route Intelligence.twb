    <worksheet name='Dynamic KPI Trend'>
      <layout-options>
        <title>
          <formatted-text>
            <run bold='true' fontcolor='#f5f5f5' fontname='Benton Sans Book' fontsize='9'>KPI Trend Analysis</run>
          </formatted-text>
        </title>
      </layout-options>
      <table>
        <view>
          <datasources>
            <datasource caption='fact_flight_operations+' name='federated.0uq9dou0g6d0sb1e1jjma14uf0mf' />
            <datasource name='Parameters' />
          </datasources>
          <datasource-dependencies datasource='Parameters'>
            <column caption='Select KPI' datatype='string' name='[Parameter 2]' param-domain-type='list' role='measure' type='nominal' value='&quot;Revenue&quot;'>
              <calculation class='tableau' formula='&quot;Revenue&quot;' />
            </column>
          </datasource-dependencies>
          <datasource-dependencies datasource='federated.0uq9dou0g6d0sb1e1jjma14uf0mf'>
            <column caption='Selected KPI' datatype='real' name='[Calculation_2536856546668548]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='CASE [Parameters].[Parameter 2]&#13;&#10;&#13;&#10;WHEN &quot;Revenue&quot;&#13;&#10;THEN SUM([revenue])&#13;&#10;&#13;&#10;WHEN &quot;Flights&quot;&#13;&#10;THEN COUNT([flight_id])&#13;&#10;&#13;&#10;WHEN &quot;Bookings&quot;&#13;&#10;THEN COUNT([booking_id])&#13;&#10;&#13;&#10;WHEN &quot;Passengers&quot;&#13;&#10;THEN SUM([passenger_count])&#13;&#10;&#13;&#10;WHEN &quot;Occupancy&quot;&#13;&#10;THEN AVG([occupancy_rate])&#13;&#10;&#13;&#10;END' />
            </column>
            <column caption='Booking Id' datatype='string' name='[booking_id]' role='dimension' type='nominal' />
            <column caption='Flight Id' datatype='string' name='[flight_id]' role='dimension' type='nominal' />
            <column caption='Month Name' datatype='string' name='[month_name]' role='dimension' type='nominal' />
            <column-instance column='[month_name]' derivation='None' name='[none:month_name:nk]' pivot='key' type='nominal' />
            <column caption='Occupancy Rate' datatype='real' name='[occupancy_rate]' role='measure' type='quantitative' />
            <column caption='Passenger Count' datatype='integer' name='[passenger_count]' role='measure' type='quantitative' />
            <column caption='Revenue' datatype='real' name='[revenue]' role='measure' type='quantitative' />
            <column-instance column='[Calculation_2536856546668548]' derivation='User' name='[usr:Calculation_2536856546668548:qk]' pivot='key' type='quantitative' />
          </datasource-dependencies>
          <aggregation value='true' />
        </view>
