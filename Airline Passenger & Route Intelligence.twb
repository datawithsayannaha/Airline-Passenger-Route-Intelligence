    <worksheet name='Flight Completion Funnel'>
      <layout-options>
        <title>
          <formatted-text>
            <run bold='true' fontalignment='1' fontcolor='#f5f5f5' fontname='Benton Sans Book' fontsize='8'>Flight Operations</run>
          </formatted-text>
        </title>
      </layout-options>
      <table>
        <view>
          <datasources>
            <datasource caption='fact_flight_operations+' name='federated.0uq9dou0g6d0sb1e1jjma14uf0mf' />
          </datasources>
          <datasource-dependencies datasource='federated.0uq9dou0g6d0sb1e1jjma14uf0mf'>
            <column caption='Scheduled Flights' datatype='integer' name='[Calculation_2536856762716170]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='COUNT([flight_id])' />
            </column>
            <column caption='Completed Flights' datatype='integer' name='[Calculation_2536856762818571]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='COUNT(&#13;&#10;IF [is_cancelled] = 0&#13;&#10;THEN [flight_id]&#13;&#10;END&#13;&#10;)' />
            </column>
            <column caption='Cancelled Flights' datatype='integer' name='[Calculation_2536856762916876]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='COUNT(&#13;&#10;IF [is_cancelled] = 1&#13;&#10;THEN [flight_id]&#13;&#10;END&#13;&#10;)' />
            </column>
            <column caption='Flight Id' datatype='string' name='[flight_id]' role='dimension' type='nominal' />
            <column caption='Is Cancelled' datatype='integer' name='[is_cancelled]' role='measure' type='quantitative' />
            <column-instance column='[Calculation_2536856762716170]' derivation='User' name='[usr:Calculation_2536856762716170:qk]' pivot='key' type='quantitative' />
            <column-instance column='[Calculation_2536856762818571]' derivation='User' name='[usr:Calculation_2536856762818571:qk]' pivot='key' type='quantitative' />
            <column-instance column='[Calculation_2536856762916876]' derivation='User' name='[usr:Calculation_2536856762916876:qk]' pivot='key' type='quantitative' />
          </datasource-dependencies>
          <filter class='categorical' column='[federated.0uq9dou0g6d0sb1e1jjma14uf0mf].[:Measure Names]'>
            <groupfilter function='union' user:op='manual'>
