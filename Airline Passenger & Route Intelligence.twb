      <aliases enabled='yes' />
      <column caption='Occupancy Rate %' datatype='string' name='[Calculation_1774625632514048]' role='measure' type='nominal'>
        <calculation class='tableau' formula='STR(ROUND(AVG([occupancy_rate]),1)) + &quot;%&quot;' />
      </column>
      <column caption='Fare Revenue' datatype='real' name='[Calculation_1913988869738496]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([fare_amount])' />
      </column>
      <column caption='Tax Revenue' datatype='real' name='[Calculation_1913988869795841]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([tax_amount])' />
      </column>
      <column caption='Discount Value' datatype='real' name='[Calculation_1913988869881858]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([discount_amount])' />
      </column>
      <column caption='Spending Segment' datatype='string' name='[Calculation_1913988912549892]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [total_amount] &lt; 15000 THEN &quot;Low Value&quot;&#13;&#10;&#13;&#10;ELSEIF [total_amount] &lt; 20000 THEN &quot;Medium Value&quot;&#13;&#10;&#13;&#10;ELSEIF [total_amount] &lt; 50000 THEN &quot;High Value&quot;&#13;&#10;&#13;&#10;ELSE &quot;Premium&quot;&#13;&#10;END' />
      </column>
      <column caption='Selected KPI 1' datatype='real' name='[Calculation_1913989121810438]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='CASE [Parameters].[Parameter 3]&#13;&#10;&#13;&#10;WHEN &quot;Revenue&quot; THEN SUM([revenue])&#13;&#10;&#13;&#10;WHEN &quot;Passengers&quot; THEN SUM([passenger_count])&#13;&#10;&#13;&#10;WHEN &quot;Occupancy&quot; THEN AVG([occupancy_rate])&#13;&#10;&#13;&#10;WHEN &quot;Delay&quot; THEN AVG([delay_minutes])&#13;&#10;&#13;&#10;END' />
      </column>
      <column caption='Calculation1' datatype='real' name='[Calculation_1997820631003136]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='Avg Occupancy = AVG([occupancy_rate]) / 100' />
      </column>
      <column caption='Cancellation Rate' datatype='real' name='[Calculation_1997820632518657]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([is_cancelled])&#13;&#10;/&#13;&#10;COUNT([flight_id])' />
      </column>
      <column caption='Booking %' datatype='real' name='[Calculation_1997820882382854]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNT([booking_id])&#13;&#10;/&#13;&#10;TOTAL(COUNT([booking_id]))'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='Domestic Flights' datatype='integer' name='[Calculation_1997820890750983]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [route_type] = &apos;Domestic&apos;&#13;&#10;THEN 1&#13;&#10;END' />
      </column>
      <column caption='International Flights' datatype='integer' name='[Calculation_1997820890923016]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [route_type] = &apos;International&apos;&#13;&#10;THEN 1&#13;&#10;END' />
      </column>
      <column caption='Domestic Negative' datatype='integer' name='[Calculation_1997820891570185]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='-COUNT([Calculation_1997820890750983])' />
      </column>
      <column caption='Flight Mix' datatype='string' name='[Calculation_1997820893151242]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='&quot;Flight Mix&quot;' />
      </column>
      <column caption='Flight Share %' datatype='real' default-format='p0.0%' name='[Calculation_1997820948205580]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNT([flight_id]) / TOTAL(COUNT([flight_id]))'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='Actual Occupancy %' datatype='real' name='[Calculation_2536856540753920]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='AVG([occupancy_rate])' />
      </column>
      <column caption='Occupancy Gap' datatype='real' name='[Calculation_2536856543436803]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='85 - [Calculation_2536856540753920]' />
      </column>
      <column caption='Selected KPI' datatype='real' name='[Calculation_2536856546668548]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='CASE [Parameters].[Parameter 2]&#13;&#10;&#13;&#10;WHEN &quot;Revenue&quot;&#13;&#10;THEN SUM([revenue])&#13;&#10;&#13;&#10;WHEN &quot;Flights&quot;&#13;&#10;THEN COUNT([flight_id])&#13;&#10;&#13;&#10;WHEN &quot;Bookings&quot;&#13;&#10;THEN COUNT([booking_id])&#13;&#10;&#13;&#10;WHEN &quot;Passengers&quot;&#13;&#10;THEN SUM([passenger_count])&#13;&#10;&#13;&#10;WHEN &quot;Occupancy&quot;&#13;&#10;THEN AVG([occupancy_rate])&#13;&#10;&#13;&#10;END' />
      </column>
      <column caption='Dynamic Title' datatype='string' name='[Calculation_2536856547430405]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='[Parameters].[Parameter 2] + &quot; Trend&quot;' />
      </column>
      <column caption='Last Month' datatype='boolean' name='[Calculation_2536856551223302]' role='measure' type='nominal'>
        <calculation class='tableau' formula='LAST() = 0'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='Airline Rank' datatype='integer' name='[Calculation_2536856749744135]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='RANK_DENSE(SUM([revenue]),&apos;desc&apos;)'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='Scheduled Flights' datatype='integer' name='[Calculation_2536856762716170]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNT([flight_id])' />
      </column>
      <column caption='Completed Flights' datatype='integer' name='[Calculation_2536856762818571]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNT(&#13;&#10;IF [is_cancelled] = 0&#13;&#10;THEN [flight_id]&#13;&#10;END&#13;&#10;)' />
      </column>
      <column caption='Cancelled Flights' datatype='integer' name='[Calculation_2536856762916876]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNT(&#13;&#10;IF [is_cancelled] = 1&#13;&#10;THEN [flight_id]&#13;&#10;END&#13;&#10;)' />
      </column>
      <column aggregation='None' caption='Delay Minutes (bin)' datatype='integer' name='[Delay Minutes (bin)]' role='dimension' type='ordinal'>
        <calculation class='bin' decimals='1' formula='[delay_minutes]' peg='0' size='10' />
      </column>
      <column aggregation='None' caption='Discount Amount (bin)' datatype='integer' name='[Discount Amount (bin)]' role='dimension' type='ordinal'>
        <calculation class='bin' decimals='3' formula='[discount_amount]' peg='0' size='1000' />
      </column>
